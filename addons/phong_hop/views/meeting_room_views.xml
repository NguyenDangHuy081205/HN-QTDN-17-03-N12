<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_meeting_room_tree" model="ir.ui.view">
        <field name="name">meeting.room.tree</field>
        <field name="model">meeting.room</field>
        <field name="arch" type="xml">
            <tree string="Danh sách phòng họp">
                <field name="name"/>
                <field name="location"/>
                <field name="capacity"/>
                <field name="booking_count"/>
                <field name="total_hours_used" widget="float_time"/>
                <field name="status" widget="badge" decoration-success="status == 'free'" decoration-warning="status == 'occupied'" decoration-danger="status == 'maintenance'"/>
                <field name="user_can_manage_room_ui" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_meeting_room_form" model="ir.ui.view">
        <field name="name">meeting.room.form</field>
        <field name="model">meeting.room</field>
        <field name="arch" type="xml">
            <form string="Phòng họp">
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_meeting_booking)d" type="action" class="oe_stat_button" icon="fa-calendar" context="{'default_meeting_room_id': active_id, 'search_default_meeting_room_id': active_id}">
                            <field name="booking_count" widget="statinfo" string="Lượt đặt"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-clock-o" disabled="1">
                            <field name="total_hours_used" widget="statinfo" string="Giờ sử dụng"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Tên phòng..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="location"/>
                            <field name="capacity"/>
                            <field name="phong_ban_quan_ly_id"/>
                        </group>
                        <group>
                            <field name="manual_status" widget="radio"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lịch sử đặt phòng">
                            <field name="booking_ids" readonly="1">
                                <tree string="Lịch đặt phòng" decoration-success="state == 'approved'" decoration-muted="state == 'rejected'">
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="organizer_id"/>
                                    <field name="description"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_meeting_room" model="ir.actions.act_window">
        <field name="name">Phòng họp</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">meeting.room</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo phòng họp mới
            </p>
        </field>
    </record>
</odoo>
