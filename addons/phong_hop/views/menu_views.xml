<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top level menu -->
    <menuitem id="menu_phong_hop_root" name="Phòng họp" sequence="10"/>

    <!-- Sub menu -->
    <menuitem id="menu_meeting_room_main" name="Quản lý phòng" parent="menu_phong_hop_root" sequence="10"/>
    <menuitem id="menu_meeting_booking_main" name="Quản lý đặt phòng" parent="menu_phong_hop_root" sequence="20"/>

    <!-- Action menu -->
    <menuitem id="menu_meeting_room_list"
              name="Danh sách phòng họp"
              parent="menu_meeting_room_main"
              action="action_meeting_room"
              sequence="10"/>

    <menuitem id="menu_meeting_booking_list"
              name="Danh sách mượn phòng"
              parent="menu_meeting_booking_main"
              action="action_meeting_booking"
              sequence="10"/>

    <!-- Thống kê - chỉ 1 menu duy nhất -->
    <menuitem id="menu_meeting_statistics"
              name="Thống kê sử dụng"
              parent="menu_phong_hop_root"
              action="action_meeting_statistics"
              sequence="30"/>

    <!-- Config Menu -->
    <menuitem id="menu_phong_hop_config"
              name="Cấu hình"
              parent="menu_phong_hop_root"
              sequence="100"/>

    <menuitem id="menu_phong_hop_permission"
              name="Phân quyền tài khoản"
              parent="menu_phong_hop_config"
              action="action_phong_hop_permission"
              groups="base.group_system"
              sequence="10"/>
</odoo>
