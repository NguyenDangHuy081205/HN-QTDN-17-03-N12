<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron job tự động cập nhật trạng thái phòng họp -->
    <record id="ir_cron_update_meeting_room_status" model="ir.cron">
        <field name="name">Cập nhật trạng thái phòng họp tự động</field>
        <field name="model_id" ref="model_meeting_booking"/>
        <field name="state">code</field>
        <field name="code">model._auto_update_room_status()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall">False</field>
    </record>
</odoo>
